{
  "manifest_version": 3,
  "name": "Live Translate DE",
  "version": "1.0.0",
  "description": "Übersetzt englische Videos und Livestreams live mit Gemini – inklusive intelligenter Originalton-Absenkung.",
  "permissions": ["tabCapture", "offscreen", "storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "minimum_chrome_version": "116",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Live Translate DE",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
